{
  "manifest_version": 3,
  "name": "Instagram Cleaner",
  "version": "1.0",
  "description": "Instagramのボタンを非表示にできる拡張機能",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "設定を開く"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_start" 
    }
  ]
}